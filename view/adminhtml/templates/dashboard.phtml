<?php

declare(strict_types=1);

/** @var \RKD\LlmsTxt\Block\Adminhtml\Dashboard $block */
$generateUrl = $block->getGenerateUrl();
$previewUrl = $block->getPreviewUrl();
$isGenerated = $block->isGenerated();
$llmsTxtUrl = $block->getLlmsTxtUrl();
$fullTxtUrl = $block->getFullTxtUrl();
?>

<div class="rkd-llmstxt-dashboard" style="max-width: 800px;">
    <div class="admin__page-section">
        <div class="admin__page-section-title">
            <span class="title"><?= $block->escapeHtml(__('Generate LLMs.txt Files')) ?></span>
        </div>
        <div class="admin__page-section-content">
            <p><?= $block->escapeHtml(
                __('Generate llms.txt and llms-full.txt files for your store. These files help AI assistants like ChatGPT, Claude, and Perplexity discover and understand your product catalog.')
            ) ?></p>

            <div style="margin: 20px 0;">
                <button id="rkd_generate_btn" type="button" class="action-default scalable action-primary">
                    <span><?= $block->escapeHtml(__('Generate Now')) ?></span>
                </button>
                <a href="<?= $block->escapeUrl($previewUrl) ?>" target="_blank"
                   class="action-default scalable" style="margin-left: 10px;">
                    <span><?= $block->escapeHtml(__('Preview Output')) ?></span>
                </a>
            </div>

            <div id="rkd_generate_result" style="margin-top: 15px;"></div>
        </div>
    </div>

    <?php if ($isGenerated): ?>
    <div class="admin__page-section" style="margin-top: 20px;">
        <div class="admin__page-section-title">
            <span class="title"><?= $block->escapeHtml(__('File URLs')) ?></span>
        </div>
        <div class="admin__page-section-content">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th class="data-grid-th"><?= $block->escapeHtml(__('File')) ?></th>
                        <th class="data-grid-th"><?= $block->escapeHtml(__('URL')) ?></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>llms.txt</td>
                        <td><a href="<?= $block->escapeUrl($llmsTxtUrl) ?>" target="_blank"><?= $block->escapeHtml($llmsTxtUrl) ?></a></td>
                    </tr>
                    <tr>
                        <td>llms-full.txt</td>
                        <td><a href="<?= $block->escapeUrl($fullTxtUrl) ?>" target="_blank"><?= $block->escapeHtml($fullTxtUrl) ?></a></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    <?php endif; ?>
</div>

<script>
    require(['jquery'], function ($) {
        $('#rkd_generate_btn').on('click', function () {
            var $btn = $(this);
            var $result = $('#rkd_generate_result');

            $btn.prop('disabled', true).find('span').text('<?= $block->escapeJs(__('Generating...')) ?>');
            $result.html('');

            $.ajax({
                url: '<?= $block->escapeJs($generateUrl) ?>',
                type: 'POST',
                dataType: 'json',
                data: { form_key: FORM_KEY },
                success: function (response) {
                    $btn.prop('disabled', false).find('span').text('<?= $block->escapeJs(__('Generate Now')) ?>');
                    if (response.success) {
                        $result.html(
                            '<div class="message message-success">' +
                            '<span>Generated successfully! ' +
                            'Sections: ' + response.sections_count +
                            ' | Products: ' + response.products_count +
                            ' | Size: ' + response.file_size +
                            ' | Duration: ' + response.duration + 's</span></div>'
                        );
                    } else {
                        $result.html(
                            '<div class="message message-error"><span>' +
                            (response.message || 'Generation failed') + '</span></div>'
                        );
                    }
                },
                error: function () {
                    $btn.prop('disabled', false).find('span').text('<?= $block->escapeJs(__('Generate Now')) ?>');
                    $result.html(
                        '<div class="message message-error"><span>Request failed. Check logs.</span></div>'
                    );
                }
            });
        });
    });
</script>
