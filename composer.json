{
    "name": "rkd/module-llms-txt",
    "description": "Generate llms.txt and llms-full.txt files for Magento 2 stores. Makes your e-commerce catalog discoverable by AI assistants.",
    "type": "magento2-module",
    "version": "1.0.0",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "magento/framework": ">=103.0.8",
        "magento/module-store": ">=101.1.0",
        "magento/module-cms": ">=104.0.0",
        "magento/module-catalog": ">=104.0.0",
        "magento/module-catalog-inventory": ">=100.4.0",
        "magento/module-cron": ">=100.4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.7",
        "magento/magento-coding-standard": "^33"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "RKD\\LlmsTxt\\": ""
        }
    },
    "keywords": [
        "magento2",
        "llms",
        "llms-txt",
        "ai",
        "seo",
        "e-commerce",
        "chatgpt",
        "claude",
        "perplexity"
    ],
    "authors": [
        {
            "name": "Robin Dhiman",
            "homepage": "https://github.com/iamrobindhiman",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/iamrobindhiman/magento2-module-llms-txt/issues",
        "source": "https://github.com/iamrobindhiman/magento2-module-llms-txt"
    },
    "minimum-stability": "stable"
}
